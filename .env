# Example Supabase configuration (do not commit real secrets)
# Copy this file to .env.local and fill in real values

# Supabase Configuration (Production/Default)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_PROJECT_ID=your-project-id
# DATABASE_URL=postgresql://user:password@host:5432/database

# Local/Development Override (Used only when running on localhost)
# VITE_LOCAL_SUPABASE_URL=http://localhost:54321
# VITE_LOCAL_SUPABASE_ANON_KEY=your-local-anon-key

# Edge Functions (Optional overrides for local serve)
# LOCAL_SUPABASE_URL=http://localhost:54321
# LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Mercado Pago
# MP_ACCESS_TOKEN=your-mp-access-token
# MP_WEBHOOK_SECRET=your-mp-webhook-secret

# App URL (used for back_urls in Mercado Pago checkout)
# APP_URL=https://your-app.example.com

